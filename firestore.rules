rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Applications - write only from client, read only for admin
    match /applications/{applicationId} {
      allow write: if true;
      allow read: if false;
    }

    // Partners - create open (registration), read/update own doc only
    match /partners/{partnerId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.uid == partnerId;
      allow update: if request.auth != null && request.auth.uid == partnerId;
      allow delete: if false;
    }
  }
}
